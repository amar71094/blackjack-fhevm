SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_DEPLOYER_KEY=your_deployer_private_key_without_0x_prefix_or_with
BANK_FUND_ETH=0.05
BLACKJACK_CONTRACT_ADDRESS=0xYourDeployedBlackjackAddress
ORACLE_PRIVATE_KEY=0xYourOracleSignerKey
# Local dev only — do not enable in production:
# ALLOW_DEPLOYER_ORACLE_KEY=true
ORACLE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ORACLE_RPC_FALLBACKS=https://rpc.sepolia.org,https://1rpc.io/sepolia
ORACLE_POLL_INTERVAL_MS=8000
ORACLE_ERROR_BACKOFF_MS=15000