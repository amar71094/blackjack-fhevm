SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
SEPOLIA_DEPLOYER_KEY=your_deployer_private_key_without_0x_prefix_or_with
BANK_FUND_ETH=0.05
BLACKJACK_CONTRACT_ADDRESS=0xYourDeployedBlackjackAddress
ORACLE_PRIVATE_KEY=0xYourOracleSignerKey
# Local dev only — do not enable in production:
# ALLOW_DEPLOYER_ORACLE_KEY=true
ORACLE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
ORACLE_RPC_FALLBACKS=https://rpc.sepolia.org,https://1rpc.io/sepolia
ORACLE_POLL_INTERVAL_MS=3000
ORACLE_MAX_STEPS_PER_WAKE=5
ORACLE_ERROR_BACKOFF_MS=15000
ORACLE_ACTIVITY_ENABLED=true
ORACLE_ACTIVITY_HOST=127.0.0.1
ORACLE_ACTIVITY_PORT=4001
ORACLE_ACTIVITY_MAX_HANDS=100
ORACLE_ACTIVITY_CORS_ORIGIN=*